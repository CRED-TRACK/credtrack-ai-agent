# ── Backend (Cloud Run URL) ────────────────────────────────────────────────────
BACKEND_BASE_URL=https://<cloud-run-url>

# ── Internal service key — must match backend's INTERNAL_SERVICE_KEY ──────────
INTERNAL_SERVICE_KEY=                 # REQUIRED

# ── Google OAuth (same credentials as backend) ────────────────────────────────
GOOGLE_CLIENT_ID=                     # REQUIRED
GOOGLE_CLIENT_SECRET=                 # REQUIRED

# ── Ollama — auto-set to http://ollama:11434 inside docker-compose ─────────────
# Only override if running outside docker-compose
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1

# ── LLM routing ────────────────────────────────────────────────────────────────
# Default: local Ollama only
LLM_PRIMARY_PROVIDER=ollama
LLM_FALLBACK_PROVIDER=none

# To use Gemini with Ollama fail-safe:
# LLM_PRIMARY_PROVIDER=gemini
# LLM_FALLBACK_PROVIDER=ollama
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MAX_OUTPUT_TOKENS=1024
GEMINI_TEMPERATURE=0.1
GEMINI_TIMEOUT_SECONDS=60

# ── Polling intervals (optional — defaults shown) ─────────────────────────────
GMAIL_POLL_INTERVAL_MS=10800000
TRANSACTION_SCAN_INTERVAL_MINUTES=1440

# ── Deployment / runtime (optional) ───────────────────────────────────────────
PORT=8081
AKKA_CANONICAL_HOSTNAME=127.0.0.1
AKKA_CANONICAL_PORT=2551
AKKA_SNAPSHOT_DIR=/tmp/akka-snapshots
